@Composable
fun GlobalEmissionView(
    year: String,
    list: List<GlobalEmission>?
) {
    if (list == null) {
        val message = if (year == "2021") {
            "2021 年因資料來源或統計口徑不同，暫不採用。"
        } else {
            "${year} 年全球資料尚未提供。"
        }
        NoDataCard(message)
        return
    }

    val total = list.sumOf { it.value }
    val top = list.maxByOrNull { it.value }

    DataCard("前十名合計", "${"%.2f".format(total)} GtCO₂e")
    DataCard("最高排放國家", "${top?.country}｜${top?.value} GtCO₂e")

    Spacer(Modifier.height(14.dp))

    Text(
        "$year 全球主要國家排行",
        fontSize = 22.sp,
        fontWeight = FontWeight.Black,
        color = Color(0xFF12632E),
        modifier = Modifier.fillMaxWidth()
    )

    Spacer(Modifier.height(10.dp))

    val max = list.maxOf { it.value }
    list.forEachIndexed { index, item ->
        SimpleBar(
            label = "${index + 1}. ${item.country}",
            value = item.value,
            maxValue = max,
            unit = "GtCO₂e"
        )
    }
}

