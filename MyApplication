@OptIn(ExperimentalMaterial3Api::class)
fun carbonLogsToJson(logs: Map<String, List<CarbonRecord>>): String {
    val root = JSONObject()

    logs.forEach { (dateKey, records) ->
        val array = JSONArray()
        records.forEach { record ->
            array.put(
                JSONObject()
                    .put("category", record.category)
                    .put("name", record.name)
                    .put("detail", record.detail)
                    .put("carbon", record.carbon)
            )
        }
        root.put(dateKey, array)
    }

    return root.toString()
}

fun carbonLogsFromJson(json: String?): Map<String, MutableList<CarbonRecord>> {
    if (json.isNullOrBlank()) return emptyMap()

    return runCatching {
        val root = JSONObject(json)
        val result = mutableMapOf<String, MutableList<CarbonRecord>>()
        val keys = root.keys()

        while (keys.hasNext()) {
            val dateKey = keys.next()
            val array = root.getJSONArray(dateKey)
            val records = mutableListOf<CarbonRecord>()

            for (index in 0 until array.length()) {
                val item = array.getJSONObject(index)
                records.add(
                    CarbonRecord(
                        category = item.optString("category"),
                        name = item.optString("name"),
                        detail = item.optString("detail"),
                        carbon = item.optDouble("carbon", 0.0)
                    )
                )
            }

            result[dateKey] = records
        }

        result
    }.getOrDefault(emptyMap())
}

fun saveCarbonLogs(context: Context, logs: Map<String, List<CarbonRecord>>) {
    context
        .getSharedPreferences("daily_carbon_save", Context.MODE_PRIVATE)
        .edit()
        .putString("logs", carbonLogsToJson(logs))
        .apply()
}

