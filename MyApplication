fun stationsFromSegments(segments: List<Segment>): List<String> {
    if (segments.isEmpty()) return emptyList()
    val stations = mutableListOf(segments.first().from)
    segments.forEach { stations.add(it.to) }
    return stations
}

fun routeDistance(segments: List<Segment>, start: String, end: String): Double {
    val stations = stationsFromSegments(segments)
    val startIndex = stations.indexOf(start)
    val endIndex = stations.indexOf(end)
    if (startIndex == -1 || endIndex == -1 || startIndex == endIndex) return 0.0

    val from = minOf(startIndex, endIndex)
    val to = maxOf(startIndex, endIndex)

    var total = 0.0
    for (i in from until to) {
        total += segments[i].km
    }
    return String.format(Locale.US, "%.2f", total).toDouble()
}

fun hsrCarbon(start: String, end: String): Double {
    if (start == end) return 0.0
    hsrCarbonTable[start]?.get(end)?.let { return it }
    hsrCarbonTable[end]?.get(start)?.let { return it }
    return 0.0
}

