@Composable
fun StepCounterPage() {
    val context = LocalContext.current
    val prefs = remember {
        context.getSharedPreferences("step_counter_save", Context.MODE_PRIVATE)
    }

    val dateFormat = remember { SimpleDateFormat("yyyy-MM-dd", Locale.TAIWAN) }
    val displayFormat = remember { SimpleDateFormat("yyyy 年 MM 月 dd 日", Locale.TAIWAN) }

    var todayKey by remember { mutableStateOf(dateFormat.format(Date())) }
    val todayText = displayFormat.format(Date())

    val sensorManager = remember {
        context.getSystemService(Context.SENSOR_SERVICE) as SensorManager
    }

    val stepSensor = remember {
        sensorManager.getDefaultSensor(Sensor.TYPE_STEP_COUNTER)
    }

    var hasPermission by remember {
        mutableStateOf(
            ContextCompat.checkSelfPermission(
                context,
                Manifest.permission.ACTIVITY_RECOGNITION
            ) == PackageManager.PERMISSION_GRANTED
        )
    }

    val savedDate = prefs.getString("date", todayKey)
    val isSameSavedDay = savedDate == todayKey

    var baseSteps by remember {
        mutableStateOf(
            if (isSameSavedDay && prefs.contains("baseSteps")) {
                prefs.getFloat("baseSteps", 0f)
            } else {
                null
            }
        )
    }
    var lastSensorTotal by remember {
        mutableStateOf(
            if (isSameSavedDay && prefs.contains("lastSensorTotal")) {
                prefs.getFloat("lastSensorTotal", 0f)
            } else {
                null
            }
        )
    }
    var currentSteps by remember {
        mutableStateOf(
            if (isSameSavedDay) prefs.getInt("currentSteps", 0) else 0
        )
    }

    fun saveSteps() {
        prefs.edit()
            .putString("date", todayKey)
            .putInt("currentSteps", currentSteps)
            .apply()
    }

    fun saveSensorState() {
        val editor = prefs.edit()
            .putString("date", todayKey)
            .putInt("currentSteps", currentSteps)

        baseSteps?.let { editor.putFloat("baseSteps", it) }
        lastSensorTotal?.let { editor.putFloat("lastSensorTotal", it) }

        editor.apply()
    }

    fun resetTodaySteps(newBaseSteps: Float? = lastSensorTotal) {
        baseSteps = newBaseSteps
        currentSteps = 0

        val editor = prefs.edit()
            .putString("date", todayKey)
            .putInt("currentSteps", 0)

        if (newBaseSteps != null) {
            editor.putFloat("baseSteps", newBaseSteps)
        } else {
            editor.remove("baseSteps")
        }

        lastSensorTotal?.let { editor.putFloat("lastSensorTotal", it) }
        editor.apply()
    }

    val permissionLauncher = rememberLauncherForActivityResult(
        contract = ActivityResultContracts.RequestPermission()
    ) { granted ->
        hasPermission = granted
    }

    LaunchedEffect(Unit) {
        if (!hasPermission) {
            permissionLauncher.launch(Manifest.permission.ACTIVITY_RECOGNITION)
        }
    }

    LaunchedEffect(Unit) {
        while (true) {
            val realToday = dateFormat.format(Date())
            if (todayKey != realToday) {
                todayKey = realToday
                baseSteps = null
                lastSensorTotal = null
                currentSteps = 0
                prefs.edit()
                    .putString("date", realToday)
                    .putInt("currentSteps", 0)
                    .remove("baseSteps")
                    .remove("lastSensorTotal")
                    .apply()
            }
            delay(60_000)
        }
    }

    DisposableEffect(hasPermission, stepSensor, todayKey) {
        if (hasPermission && stepSensor != null) {
            val listener = object : SensorEventListener {
                override fun onSensorChanged(event: SensorEvent?) {
                    val totalSteps = event?.values?.getOrNull(0) ?: return
                    lastSensorTotal = totalSteps

                    if (baseSteps == null) {
                        baseSteps = totalSteps
                    }

                    currentSteps = (totalSteps - (baseSteps ?: totalSteps))
                        .toInt()
                        .coerceAtLeast(0)

                    saveSensorState()
                }

                override fun onAccuracyChanged(sensor: Sensor?, accuracy: Int) {}
            }

            sensorManager.registerListener(
                listener,
                stepSensor,
                SensorManager.SENSOR_DELAY_UI
            )

            onDispose {
                sensorManager.unregisterListener(listener)
            }
        } else {
            onDispose {}
        }
    }

    LaunchedEffect(currentSteps, todayKey) {
        saveSteps()
    }

    val savedCarbon = currentSteps / 10000.0 * 1.3
    val calories = currentSteps / 10000.0 * 350

    Column(
