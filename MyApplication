            textAlign = TextAlign.Center,
            lineHeight = 22.sp
        )

        Spacer(Modifier.height(16.dp))

        Card(
            modifier = Modifier.fillMaxWidth(),
            shape = RoundedCornerShape(22.dp),
            colors = CardDefaults.cardColors(containerColor = Color.White)
        ) {
            Row(
                modifier = Modifier.padding(18.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                LineIcon("calendar", true)

                Spacer(Modifier.width(12.dp))

                Column {
                    Text("今日日期", color = Color(0xFF64806D), fontSize = 14.sp)
                    Text(
                        todayText,
                        color = Color(0xFF12632E),
                        fontSize = 20.sp,
                        fontWeight = FontWeight.Bold
                    )
                }
            }
        }

        Spacer(Modifier.height(18.dp))

        if (stepSensor == null) {
            NoDataCard("這台裝置沒有支援計步器感測器，可能需要使用實體手機測試。")
            return@Column
        }

        if (!hasPermission) {
            NoDataCard("需要允許活動辨識權限，才能讀取計步器資料。")

            Spacer(Modifier.height(12.dp))

            Button(
                onClick = {
                    permissionLauncher.launch(Manifest.permission.ACTIVITY_RECOGNITION)
                },
                colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF23853B)),
                shape = RoundedCornerShape(50.dp)
            ) {
                Text("允許計步器權限")
            }

            return@Column
        }

        Card(
            modifier = Modifier.fillMaxWidth(),
            shape = RoundedCornerShape(28.dp),
            colors = CardDefaults.cardColors(containerColor = Color(0xFFDCF5D5))
        ) {
            Column(
                modifier = Modifier.padding(26.dp),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                Text(
                    "今日步數",
                    color = Color(0xFF12632E),
                    fontSize = 18.sp,
                    fontWeight = FontWeight.Bold
                )

                Spacer(Modifier.height(8.dp))

                Text(
                    "$currentSteps 步",
                    color = Color(0xFF12632E),
                    fontSize = 44.sp,
                    fontWeight = FontWeight.Black
                )

                Spacer(Modifier.height(8.dp))

                Text(
                    "每 10000 步約可減少 1.3 kg CO2e，並消耗約 350 kcal。",
                    color = Color(0xFF5F7668),
                    fontSize = 13.sp,
                    textAlign = TextAlign.Center
                )
            }
        }

        Spacer(Modifier.height(16.dp))

        DataCard("減少碳排放", "${"%.4f".format(savedCarbon)} kg CO2e")
        DataCard("消耗熱量", "${"%.0f".format(calories)} kcal")

        Spacer(Modifier.height(16.dp))

        Button(
            onClick = {
