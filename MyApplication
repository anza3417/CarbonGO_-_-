fun calculateRecord(
    recordType: RecordType,
    transportName: String,
    distance: String,
    hsrStart: String,
    hsrEnd: String,
    mrtLine: String,
    mrtStart: String,
    mrtEnd: String,
    applianceName: String,
    watt: String,
    hours: String,
    days: String,
    waterAmount: String,
    gasName: String,
    gasAmount: String
): CarbonRecord {
    fun d(v: String) = v.toDoubleOrNull() ?: 0.0

    return when (recordType) {
        RecordType.TRANSPORT -> {
            if (transportName == "高鐵") {
                val km = routeDistance(hsrSegments, hsrStart, hsrEnd)
                val carbon = hsrCarbon(hsrStart, hsrEnd)
                CarbonRecord(
                    category = "交通",
                    name = "高鐵｜$hsrStart 到 $hsrEnd",
                    detail = "$km 公里｜官方站間碳足跡 ${"%.2f".format(carbon)} kg CO2e",
                    carbon = carbon
                )
            } else if (transportName == "捷運") {
                val km = routeDistance(mrtSegments[mrtLine] ?: emptyList(), mrtStart, mrtEnd)
                val factor = 0.0132
                CarbonRecord(
                    category = "交通",
                    name = "捷運 $mrtLine｜$mrtStart 到 $mrtEnd",
                    detail = "$km 公里 x $factor kgCO2e/km",
                    carbon = km * factor
                )
            } else {
                val factor = mapOf(
                    "公車" to 0.0286,
                    "客運" to 0.0286,
                    "機車" to 0.0500,
                    "汽車" to 0.1020,
                    "電動自行車" to 0.0,
                    "腳踏車" to 0.0,
                    "步行" to 0.0
                )[transportName] ?: 0.0

                val km = d(distance)

                CarbonRecord(
                    category = "交通",
                    name = transportName,
                    detail = "$km 公里 x $factor kgCO2e/km",
                    carbon = km * factor
                )
            }
        }

        RecordType.ELECTRIC -> {
            val kwh = d(watt) / 1000.0 * d(hours) * d(days)
            CarbonRecord(
                category = "電力",
                name = applianceName.substringBefore("｜"),
                detail = "${"%.4f".format(kwh)} 度 x 0.494",
                carbon = kwh * 0.494
            )
        }

        RecordType.WATER -> {
            val amount = d(waterAmount)
            CarbonRecord(
                category = "水",
                name = "自來水",
                detail = "$amount 度 x 0.159",
                carbon = amount * 0.159
            )
        }

        RecordType.GAS -> {
            val amount = d(gasAmount)
            val factor = if (gasName.contains("LPG")) 2.21 else 2.643
            val unit = if (gasName.contains("LPG")) "L" else "m3"
            CarbonRecord(
                category = "瓦斯",
                name = gasName,
                detail = "$amount $unit x $factor",
                carbon = amount * factor
            )
        }
    }
}

