@Composable
fun LineIcon(type: String, selected: Boolean) {
    val color = if (selected) Color(0xFF12632E) else Color(0xFF6F8174)

    Canvas(modifier = Modifier.size(26.dp)) {
        val stroke = Stroke(width = 3f)

        when (type) {
            "home", "calendar" -> {
                drawRect(color, topLeft = Offset(5f, 7f), size = Size(size.width - 10f, size.height - 8f), style = stroke)
                drawLine(color, Offset(5f, 13f), Offset(size.width - 5f, 13f), strokeWidth = 3f)
                drawLine(color, Offset(10f, 4f), Offset(10f, 10f), strokeWidth = 3f)
                drawLine(color, Offset(20f, 4f), Offset(20f, 10f), strokeWidth = 3f)
            }

            "leaf" -> {
                drawOval(color, topLeft = Offset(6f, 5f), size = Size(16f, 20f), style = stroke)
                drawLine(color, Offset(20f, 8f), Offset(7f, 24f), strokeWidth = 3f)
            }

            "globe" -> {
                drawCircle(color, radius = size.minDimension / 2.5f, center = center, style = stroke)
                drawLine(color, Offset(center.x, 5f), Offset(center.x, size.height - 5f), strokeWidth = 2.5f)
                drawLine(color, Offset(5f, center.y), Offset(size.width - 5f, center.y), strokeWidth = 2.5f)
            }

            "chart" -> {
                drawLine(color, Offset(6f, size.height - 6f), Offset(size.width - 4f, size.height - 6f), strokeWidth = 3f)
                drawLine(color, Offset(8f, size.height - 6f), Offset(8f, 10f), strokeWidth = 3f)
                drawLine(color, Offset(11f, 18f), Offset(16f, 13f), strokeWidth = 3f)
                drawLine(color, Offset(16f, 13f), Offset(21f, 16f), strokeWidth = 3f)
                drawLine(color, Offset(21f, 16f), Offset(25f, 8f), strokeWidth = 3f)
            }

            "game" -> {
                drawRoundRect(
                    color,
                    topLeft = Offset(4f, 9f),
                    size = Size(size.width - 8f, 14f),
                    cornerRadius = CornerRadius(6f, 6f),
                    style = stroke
                )
                drawLine(color, Offset(10f, 16f), Offset(16f, 16f), strokeWidth = 3f)
                drawLine(color, Offset(13f, 13f), Offset(13f, 19f), strokeWidth = 3f)
                drawCircle(color, radius = 2.2f, center = Offset(21f, 15f))
                drawCircle(color, radius = 2.2f, center = Offset(26f, 18f))
            }
            "step" -> {
                drawOval(color, Offset(8f, 5f), Size(10f, 18f), style = stroke)
                drawOval(color, Offset(20f, 14f), Size(9f, 16f), style = stroke)
                drawOval(color, Offset(8f, 31f), Size(10f, 18f), style = stroke)
                drawOval(color, Offset(22f, 40f), Size(9f, 16f), style = stroke)
            }
        }
    }
}
