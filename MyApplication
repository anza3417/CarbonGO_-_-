@Composable
fun FarmGameScreen(onBack: () -> Unit) {
    val context = LocalContext.current
    val prefs = remember {
        context.getSharedPreferences("farm_game_save", Context.MODE_PRIVATE)
    }

    var now by remember { mutableStateOf(System.currentTimeMillis()) }
    var coins by remember { mutableStateOf(prefs.getInt("coins", 1000)) }
    var tickets by remember { mutableStateOf(prefs.getInt("tickets", 0)) }
    var currentSteps by remember { mutableStateOf(prefs.getInt("currentSteps", 0)) }
    var stepBonusUsed by remember { mutableStateOf(prefs.getInt("stepBonusUsed", currentSteps / STEP_REWARD_STEPS)) }

    var houseUnlocked by remember { mutableStateOf(prefs.getBoolean("houseUnlocked", false)) }
    var field2Unlocked by remember { mutableStateOf(prefs.getBoolean("field2Unlocked", false)) }
    var field3Unlocked by remember { mutableStateOf(prefs.getBoolean("field3Unlocked", false)) }
    var showBag by remember { mutableStateOf(false) }
    var showShop by remember { mutableStateOf(false) }
    var showExchange by remember { mutableStateOf(false) }
    var choosingField by remember { mutableStateOf<Int?>(null) }
    var selectedCrop by remember { mutableStateOf<Pair<Int, PlantedCrop>?>(null) }

    val savedStepsAtOpen = remember { currentSteps }
    val bagItems = remember {
        mutableStateListOf<BagItem>().apply {
            addAll(bagItemsFromJson(prefs.getString("bagItems", "[]")))
        }
    }
    var field1Crop by remember { mutableStateOf(cropFromJson(prefs.getString("field1Crop", ""))) }
    var field2Crop by remember { mutableStateOf(cropFromJson(prefs.getString("field2Crop", ""))) }
    var field3Crop by remember { mutableStateOf(cropFromJson(prefs.getString("field3Crop", ""))) }

    fun reduceGrowingTime(amountMs: Long) {
        field1Crop = field1Crop?.let { it.copy(timeReducedMs = it.timeReducedMs + amountMs) }
        field2Crop = field2Crop?.let { it.copy(timeReducedMs = it.timeReducedMs + amountMs) }
        field3Crop = field3Crop?.let { it.copy(timeReducedMs = it.timeReducedMs + amountMs) }
    }

    LaunchedEffect(Unit) {
        while (true) {
            now = System.currentTimeMillis()
            delay(1000)
        }
    }

    LaunchedEffect(
        coins,
        tickets,
        currentSteps,
        stepBonusUsed,
        houseUnlocked,
        field2Unlocked,
        field3Unlocked,
        bagItems.toList(),
        field1Crop,
        field2Crop,
        field3Crop
    ) {
        prefs.edit()
            .putInt("coins", coins)
            .putInt("tickets", tickets)
            .putInt("currentSteps", currentSteps)
            .putInt("stepBonusUsed", stepBonusUsed)
            .putBoolean("houseUnlocked", houseUnlocked)
            .putBoolean("field2Unlocked", field2Unlocked)
            .putBoolean("field3Unlocked", field3Unlocked)
            .putString("bagItems", bagItemsToJson(bagItems))
            .putString("field1Crop", cropToJson(field1Crop))
            .putString("field2Crop", cropToJson(field2Crop))
            .putString("field3Crop", cropToJson(field3Crop))
            .apply()
    }

    FarmStepTracker(
        onStepsChanged = { sessionSteps ->
            currentSteps = savedStepsAtOpen + sessionSteps
            val bonusNow = currentSteps / STEP_REWARD_STEPS
            if (bonusNow > stepBonusUsed) {
                val diff = bonusNow - stepBonusUsed
                stepBonusUsed = bonusNow
                reduceGrowingTime(diff * STEP_REWARD_REDUCE_MS)
                Toast.makeText(context, "步數達標，作物成長減少 ${diff * 10} 分鐘", Toast.LENGTH_SHORT).show()
            }
        }
    )

    BoxWithConstraints(
        modifier = Modifier
            .fillMaxSize()
            .background(Color(0xFF94D96C))
    ) {
        Image(
            painter = painterResource(id = R.drawable.fm),
            contentDescription = "農場背景",
            modifier = Modifier.fillMaxSize(),
            contentScale = ContentScale.Crop
        )

        FarmStatusPanel(
            coins = coins,
            tickets = tickets,
            cabbage = bagItems.firstOrNull { it.name == "高麗菜" }?.count ?: 0,
            modifier = Modifier
                .align(Alignment.TopEnd)
                .padding(top = 12.dp, end = 12.dp)
        )

        FarmStepCircle(
            steps = currentSteps,
            modifier = Modifier
                .align(Alignment.TopEnd)
                .padding(top = 68.dp, end = 18.dp)
                .size(70.dp)
        )

        FarmLandButton(
            unlocked = houseUnlocked,
            lockText = "500",
            modifier = Modifier
                .offset(x = maxWidth * 0.06f, y = maxHeight * 0.055f)
                .width(maxWidth * 0.30f)
                .height(maxHeight * 0.085f),
            onClick = {
                if (houseUnlocked) {
                    Toast.makeText(context, "房子功能之後開放", Toast.LENGTH_SHORT).show()
                } else if (coins >= 500) {
                    coins -= 500
                    houseUnlocked = true
                    Toast.makeText(context, "已解鎖房子土地", Toast.LENGTH_SHORT).show()
                } else {
                    Toast.makeText(context, "金幣不足，需要 500 金幣", Toast.LENGTH_SHORT).show()
                }
            }
        )

        FarmCropPatch(
            crop = field3Crop,
            now = now,
            modifier = Modifier
                .offset(x = maxWidth * 0.12f, y = maxHeight * 0.245f)
                .width(maxWidth * 0.64f)
                .height(maxHeight * 0.16f),
            onClick = {
                field3Crop?.let { selectedCrop = 3 to it }
            }
        )

        if (field3Crop == null) {
            FarmLandButton(
                unlocked = field3Unlocked,
                lockText = "1000",
                modifier = Modifier
                    .offset(x = maxWidth * 0.38f, y = maxHeight * 0.315f)
                    .width(maxWidth * 0.20f)
                    .height(maxHeight * 0.052f),
                onClick = {
                    if (field3Unlocked) {
                        choosingField = 3
                    } else if (coins >= 1000) {
                        coins -= 1000
                        field3Unlocked = true
                        Toast.makeText(context, "已解鎖第三塊田", Toast.LENGTH_SHORT).show()
                    } else {
                        Toast.makeText(context, "金幣不足，需要 1000 金幣", Toast.LENGTH_SHORT).show()
                    }
                }
            )
        }

        FarmCropPatch(
            crop = field2Crop,
            now = now,
            modifier = Modifier
                .offset(x = maxWidth * 0.08f, y = maxHeight * 0.43f)
                .width(maxWidth * 0.64f)
                .height(maxHeight * 0.16f),
            onClick = {
                field2Crop?.let { selectedCrop = 2 to it }
            }
        )

        if (field2Crop == null) {
            FarmLandButton(
                unlocked = field2Unlocked,
                lockText = "300",
                modifier = Modifier
                    .offset(x = maxWidth * 0.34f, y = maxHeight * 0.505f)
                    .width(maxWidth * 0.20f)
                    .height(maxHeight * 0.052f),
