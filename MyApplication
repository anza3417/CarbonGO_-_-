        if (field1Crop == null) {
            FarmLandButton(
                unlocked = true,
                lockText = "",
                modifier = Modifier
                    .offset(x = maxWidth * 0.30f, y = maxHeight * 0.735f)
                    .width(maxWidth * 0.18f)
                    .height(maxHeight * 0.048f),
