private const val CABBAGE_GROW_TOTAL_MS = 6L * 60L * 60L * 1000L
private const val CABBAGE_MID_STAGE_REMAINING_MS = 4L * 60L * 60L * 1000L
private const val STEP_REWARD_STEPS = 50
private const val STEP_REWARD_REDUCE_MS = 10L * 60L * 1000L
private const val WATER_COOLDOWN_MS = 60L * 60L * 1000L
private const val WATER_REDUCE_MS = 30L * 60L * 1000L

data class SeedItem(
    val emoji: String,
    val name: String,
    val price: Int,
    val imageRes: Int? = null
)

data class BagItem(
    val emoji: String,
    val name: String,
    val count: Int,
    val imageRes: Int? = null,
    val sellPrice: Int = 0,
    val isSeed: Boolean = false,
    val seed: SeedItem? = null
)

data class PlantedCrop(
    val emoji: String,
    val name: String,
    val imageRes: Int? = null,
    val plantedAt: Long = System.currentTimeMillis(),
    val timeReducedMs: Long = 0L,
    val lastWateredAt: Long = 0L
)

fun PlantedCrop.remainingMs(now: Long): Long {
    return (CABBAGE_GROW_TOTAL_MS - (now - plantedAt) - timeReducedMs).coerceAtLeast(0L)
}

fun PlantedCrop.stageImageRes(now: Long): Int? {
    val remaining = remainingMs(now)
    return when {
        imageRes == null -> null
        remaining <= 0L -> R.drawable.c11
        remaining <= CABBAGE_MID_STAGE_REMAINING_MS -> R.drawable.m11
        else -> imageRes
    }
}

fun formatFarmTime(ms: Long): String {
    val totalSeconds = (ms / 1000L).coerceAtLeast(0L)
    val hours = totalSeconds / 3600L
    val minutes = (totalSeconds % 3600L) / 60L
    val seconds = totalSeconds % 60L
    return "%02d:%02d:%02d".format(hours, minutes, seconds)
}

val farmSeeds = listOf(
