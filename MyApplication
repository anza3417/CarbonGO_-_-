fun sellPriceByName(name: String): Int {
    return when (name) {
        "高麗菜" -> 4
        "花椰菜" -> 7
        "胡蘿蔔" -> 15
        "紅蘿蔔" -> 15
        "白蘿蔔" -> 22
        "西瓜" -> 30
        "草莓" -> 40
        else -> 0
    }
}

fun produceImageResByName(name: String): Int? {
    return when (name) {
        "高麗菜" -> R.drawable.kbg
        else -> null
    }
}

fun seedByName(name: String): SeedItem? {
    return farmSeeds.firstOrNull { it.name == name }
}

fun cropNameFromSeed(seedName: String): String {
    return seedName.removeSuffix("種子")
}

fun MutableList<BagItem>.addStack(item: BagItem, maxSlots: Int = 20): Boolean {
    val index = indexOfFirst { it.name == item.name && it.isSeed == item.isSeed }
    if (index >= 0) {
        this[index] = this[index].copy(count = this[index].count + item.count)
        return true
    }
    if (size >= maxSlots) return false
    add(item)
    return true
}

fun MutableList<BagItem>.removeStack(name: String, count: Int): Boolean {
    val index = indexOfFirst { it.name == name }
    if (index < 0 || this[index].count < count) return false
    val current = this[index]
    val left = current.count - count
    if (left <= 0) removeAt(index) else this[index] = current.copy(count = left)
    return true
}

fun bagItemsToJson(items: List<BagItem>): String {
    val array = org.json.JSONArray()
    items.forEach { item ->
        array.put(
            org.json.JSONObject()
                .put("emoji", item.emoji)
                .put("name", item.name)
                .put("count", item.count)
                .put("isSeed", item.isSeed)
        )
    }
    return array.toString()
}

fun bagItemsFromJson(json: String?): List<BagItem> {
    if (json.isNullOrBlank()) return emptyList()
    return runCatching {
        val array = org.json.JSONArray(json)
        buildList {
            for (index in 0 until array.length()) {
                val obj = array.getJSONObject(index)
                val name = obj.getString("name")
                val emoji = obj.optString("emoji", "")
                val count = obj.optInt("count", 1).coerceAtLeast(1)
                val isSeed = obj.optBoolean("isSeed", false)
                val seed = if (isSeed) seedByName(name) else null

                add(
                    BagItem(
                        emoji = if (emoji.isNotBlank()) emoji else seed?.emoji ?: "📦",
                        name = name,
                        count = count,
                        imageRes = if (isSeed) seed?.imageRes else produceImageResByName(name),
                        sellPrice = if (isSeed) 0 else sellPriceByName(name),
                        isSeed = isSeed,
                        seed = seed
                    )
                )
            }
        }
    }.getOrDefault(emptyList())
}

fun cropToJson(crop: PlantedCrop?): String {
    if (crop == null) return ""
    return org.json.JSONObject()
        .put("emoji", crop.emoji)
        .put("name", crop.name)
        .put("plantedAt", crop.plantedAt)
        .put("timeReducedMs", crop.timeReducedMs)
        .put("lastWateredAt", crop.lastWateredAt)
        .toString()
}

fun cropFromJson(json: String?): PlantedCrop? {
    if (json.isNullOrBlank()) return null
    return runCatching {
        val obj = org.json.JSONObject(json)
        val name = obj.getString("name")
        val seed = farmSeeds.firstOrNull { cropNameFromSeed(it.name) == name }
        PlantedCrop(
            emoji = obj.optString("emoji", seed?.emoji ?: "🌱"),
            name = name,
            imageRes = seed?.imageRes,
            plantedAt = obj.optLong("plantedAt", System.currentTimeMillis()),
            timeReducedMs = obj.optLong("timeReducedMs", 0L),
            lastWateredAt = obj.optLong("lastWateredAt", 0L)
        )
    }.getOrNull()
}

