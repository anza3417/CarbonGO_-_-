            crop = field1Crop,
            now = now,
            modifier = Modifier
                .offset(x = maxWidth * 0.03f, y = maxHeight * 0.665f)
                .width(maxWidth * 0.62f)
                .height(maxHeight * 0.17f),
            onClick = {
                field1Crop?.let { selectedCrop = 1 to it }
            }
